# Raaya Backend local/demo environment
# Copy to .env locally or mirror these values in /home/ec2-user/.env on the demo EC2 instance.
# Keep real secrets out of git.

NODE_ENV=development
PORT=3000
AWS_REGION=us-east-1

# Cognito JWT validation
COGNITO_USER_POOL_ID=us-east-1_example
COGNITO_CLIENT_ID=example-client-id

# Optional: only use this in local/e2e tests when pointing at a local JWKS server.
# Leave empty in AWS demo/prod so the app uses the Cognito JWKS URL.
COGNITO_JWKS_URI=

# Scheduled jobs called by Lambda/EventBridge through x-job-secret.
JOB_SECRET=replace-with-a-long-random-demo-secret

# AI/Bedrock safety switch.
# Keep false by default to avoid accidental Bedrock usage and demo costs.
AI_ENABLED=false
DEMO_RESIDENT_ID=demo-resident

# S3 media bucket for future family photos/audio upload flows.
S3_MEDIA_BUCKET=raaya-demo-media-example
S3_MEDIA_PREFIX=

# Lambda-only environment value. Set this on Lambda, not necessarily in the backend container.
BACKEND_URL=http://your-demo-backend-host:3000
