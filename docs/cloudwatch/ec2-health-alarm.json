{
  "AlarmName": "raaya-demo-ec2-status-check",
  "AlarmDescription": "Graduation demo alarm for EC2 status check failures.",
  "Namespace": "AWS/EC2",
  "MetricName": "StatusCheckFailed",
  "Dimensions": [
    {
      "Name": "InstanceId",
      "Value": "REPLACE_WITH_DEMO_EC2_INSTANCE_ID"
    }
  ],
  "Statistic": "Maximum",
  "Period": 60,
  "EvaluationPeriods": 1,
  "Threshold": 0,
  "ComparisonOperator": "GreaterThanThreshold",
  "TreatMissingData": "notBreaching"
}
