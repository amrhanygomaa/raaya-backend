{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListMediaPrefixes",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::REPLACE_WITH_MEDIA_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "family-uploads/*",
            "resident-playback/*",
            "tmp/*",
            "exports/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWriteDemoMediaObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject"],
      "Resource": [
        "arn:aws:s3:::REPLACE_WITH_MEDIA_BUCKET/family-uploads/*",
        "arn:aws:s3:::REPLACE_WITH_MEDIA_BUCKET/resident-playback/*",
        "arn:aws:s3:::REPLACE_WITH_MEDIA_BUCKET/tmp/*",
        "arn:aws:s3:::REPLACE_WITH_MEDIA_BUCKET/exports/*"
      ]
    }
  ]
}
